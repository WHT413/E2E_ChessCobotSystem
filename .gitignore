# ============================================================
#  ROOT .gitignore — Chess Robot Project
# ============================================================

# ------ Python ------
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.pyc
*.egg-info/
.eggs/
dist/
build/
*.egg

# ------ Môi trường ảo ------
.venv/
venv/
env/
.env
*.env.local

# ------ YOLO Model weights (file lớn, dùng Git LFS hoặc link riêng) ------
*.pt
*.pth
*.onnx
*.weights
*.engine

# ------ Log files ------
*.log
*.txt
!ChessRobot/seeFen.txt

# ------ Video test ------
*.mp4
*.avi
*.mov
*.mkv

# ------ macOS rác ------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes

# ------ Windows rác ------
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# ------ IDE ------
.vscode/
.idea/
*.code-workspace
*.swp
*.swo
*~

# ------ Node.js ------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ------ Frontend (không push lên GitHub) ------
software/robot-chess/frontend/

# ------ Stockfish engine (binary lớn, tải về riêng) ------
stockfish/
stockfish*.exe
stockfish-*

# ------ Dữ liệu tạm / cache ------
.cache/
tmp/
temp/
.pytest_cache/
.mypy_cache/

# Bash script
*.sh
*.bat